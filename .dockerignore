# --------------------------------------------------------------------------
# .dockerignore — Files excluded from the Docker build context.
#
# Keeping node_modules and build artifacts out of the context speeds up
# `docker build` significantly and avoids conflicts with the container's
# own dependency tree.
# --------------------------------------------------------------------------

node_modules
dist
.git
*.log
.ask_user.md
ai_prompt.md
docker_readme.md
README.md
.tool-versions
